# ===========================================
# EXEMPLO DE CONFIGURACAO - Portal Visitantes
# Copie para .env e preencha os valores
# ===========================================

# Aplicacao
APP_NOME_EMPRESA=Sua Empresa
APP_LANDING_PAGE=https://www.google.com.br

# Syslog (Firewall)
SYSLOG_IP=192.168.1.1
SYSLOG_PORT=514

# Supabase Database
DB_HOST=db.seu-projeto.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=sua_senha_supabase

# Supabase API
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_ANON_KEY=sua_chave_anon_supabase

# TP-Link Omada SDN
OMADA_IP=omada.suaempresa.com.br
OMADA_PORT=8043
OMADA_USER=portalapi
OMADA_PASS=sua_senha_omada

# SERPRO ConectaGov
SERPRO_CONSUMER_KEY=sua_consumer_key
SERPRO_CONSUMER_SECRET=seu_consumer_secret
SERPRO_CPF_GESTOR=00000000000
